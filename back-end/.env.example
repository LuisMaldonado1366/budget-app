# Environment
ENVIRONMENT=ENVIRONMENT

# API SETTINGS
API_PORT=80
API_TITLE=API_TITLE
API_VERSION=1.0.0
WEB_URL=localhost:3000

# SWAGGER SETTINGS
DOCS_USER_NAME=docs_user_name
DOCS_PASSWORD=docs_password

# DOCKER SETTINGS
DOCKER_NAME=docker_name
DOCKER_EXTERNAL_NETWORK=docker_network_name
END_POINT=api.example.com

# TOKEN SETTINGS
TOKEN_SIGNATURE=secret_signature
TOKEN_ISSUER=token_issuer
TOKEN_EXPIRATION_HRS=1
TOKEN_ALGORITHM=token_algorithm

# MYSQL DB SETTINGS
SQL_DRIVER=mysql+pymysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=db_user
DB_PASSWORD=db_password
DB_NAME=db_name
